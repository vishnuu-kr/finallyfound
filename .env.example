# OpenAI-Compatible API: Required for GPT OSS or OpenAI API calls.
# VITE_OPENAI_API_KEY: Your API secret key.
VITE_OPENAI_API_KEY="your_api_key_here"

# VITE_OPENAI_API_BASE_URL: Optional. Base URL for OpenAI-compatible providers (leave empty for default OpenAI).
# Examples: 
# - Groq: https://api.groq.com/openai/v1
# - DeepSeek: https://api.deepseek.com/v1
# - OpenRouter: https://openrouter.ai/api/v1
VITE_OPENAI_API_BASE_URL=""

# VITE_OPENAI_MODEL: The model name to use.
# Examples: gpt-4o, llama-3.3-70b-versatile, deepseek-chat
VITE_OPENAI_MODEL="gpt-4o"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_TMDB_API_KEY: Required for TMDB API calls.
VITE_TMDB_API_KEY="YOUR_TMDB_API_KEY"
